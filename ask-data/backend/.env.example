# Reference template only.
# In Cloudera AI, runtime environment variables should already be injected.
# Use a local `.env` file only as an optional development fallback.
# Preserve the existing Cloudera AI variable names for compatibility.

APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false

IMPALA_HOST=your-impala-host
IMPALA_PORT=443
IMPALA_HTTP_PATH=cliservice
CDP_USER=your-cdp-username
CDP_PASS=your-cdp-password
DB_NAME=default

AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT=your-deployment-name
AZURE_OPENAI_MODEL=gpt-4o-mini

# Amazon Bedrock (non-RAG routing). AWS credentials stay server-side only.
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0
BEDROCK_MODEL_NAME=Claude Sonnet 4
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional JSON array of models to show in Model Settings (IDs + display names only).
# When unset, BEDROCK_MODEL_ID / BEDROCK_MODEL_NAME define a single catalog entry.
# BEDROCK_MODEL_CATALOG_JSON=[{"model_id":"anthropic.claude-3-5-sonnet-20240620-v1:0","model_name":"Claude 3.5 Sonnet"},{"model_id":"anthropic.claude-sonnet-4-20250514-v1:0","model_name":"Claude Sonnet 4"}]

SESSION_BACKEND=memory
SESSION_TTL_MINUTES=30
MEMORY_MAX_HISTORY=10

SQL_DEFAULT_LIMIT=100
SQL_MAX_PREVIEW_ROWS=100
SQL_ALLOWED_TABLES=customers,deposits,credits,fraud_transactions
