# =============================================================================
# Bank Jawa Timur — Ask Data PoC
# Environment Variables Reference (semua 4 CAI Applications)
# Jangan commit file .env yang sesungguhnya — hanya .env.example ini.
# =============================================================================

# -----------------------------------------------------------------------------
# [APP 1] Backend Application
# Script : ask-data/backend/backend_entry.py
# Resources: CPU, 4 vCPU, 8 GB RAM
# -----------------------------------------------------------------------------

# LLM — arahkan ke URL Qwen LLM App setelah di-deploy
LLM_PROVIDER=local_qwen
QWEN_BASE_URL=http://<qwen-app-url>/v1
QWEN_API_KEY=local-dev-token
QWEN_MODEL=Qwen/Qwen2.5-14B-Instruct-AWQ

# Impala CDW
IMPALA_HOST=coordinator-default-impala-aws.dw-go01-demo-aws.ylcu-atmi.cloudera.site
IMPALA_PORT=443
IMPALA_HTTP_PATH=cliservice
CDP_USER=<cdp-username>
CDP_PASS=<cdp-password>
DB_NAME=cai_sdx_se_indonesia

# Session
SESSION_BACKEND=sqlite
SESSION_SQLITE_PATH=data/ask_data_sessions.db
SESSION_TTL_MINUTES=60
MEMORY_MAX_HISTORY=10

# Guardrails
GUARDRAILS_ENABLED=true

# ChromaDB
CHROMA_ENABLED=true
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=bankjatim_docs
EMBED_MODEL=nomic-embed-text
OLLAMA_BASE_URL=http://<qwen-app-url>

# -----------------------------------------------------------------------------
# [APP 2] Frontend Application
# Script : ask-data/frontend/frontend_entry.py
# Resources: CPU, 2 vCPU, 4 GB RAM
# -----------------------------------------------------------------------------

BACKEND_API_BASE_URL=http://<backend-app-url>

# -----------------------------------------------------------------------------
# [APP 3] Qwen LLM Application
# Script : ask-data/qwen_inference/qwen_entry.py
# Resources: GPU L40 x1 (atau x2 dengan tensor_parallel_size=2)
# -----------------------------------------------------------------------------

QWEN_MODEL=Qwen/Qwen2.5-14B-Instruct-AWQ
QWEN_API_KEY=local-dev-token
QWEN_MAX_MODEL_LEN=8192
QWEN_GPU_MEMORY_UTILIZATION=0.90
QWEN_TENSOR_PARALLEL_SIZE=1
# Set QWEN_TENSOR_PARALLEL_SIZE=2 jika pakai kedua L40

# HuggingFace token jika model perlu didownload
HUGGING_FACE_HUB_TOKEN=<hf-token>

# -----------------------------------------------------------------------------
# [APP 4] MCP Server Application
# Script : ask-data/mcp_server/mcp_entry.py
# Resources: CPU, 2 vCPU, 4 GB RAM
# -----------------------------------------------------------------------------

# Impala CDW (sama dengan Backend App)
IMPALA_HOST=coordinator-default-impala-aws.dw-go01-demo-aws.ylcu-atmi.cloudera.site
IMPALA_PORT=443
IMPALA_HTTP_PATH=cliservice
CDP_USER=<cdp-username>
CDP_PASS=<cdp-password>
DB_NAME=cai_sdx_se_indonesia

# ChromaDB (sama persist dir dengan Backend App jika shared storage)
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=bankjatim_docs
EMBED_MODEL=nomic-embed-text
OLLAMA_BASE_URL=http://<qwen-app-url>

# -----------------------------------------------------------------------------
# [APP 5] MCP Server Aggregation
# Script : ask-data/mcp_server_aggregation/mcp_entry.py
# Resources: CPU, 2 vCPU, 4 GB RAM
# -----------------------------------------------------------------------------

# Impala CDW (sama dengan Backend App)
IMPALA_HOST=coordinator-default-impala-aws.dw-go01-demo-aws.ylcu-atmi.cloudera.site
IMPALA_PORT=443
IMPALA_HTTP_PATH=cliservice
CDP_USER=<cdp-username>
CDP_PASS=<cdp-password>
DB_NAME=cai_sdx_se_indonesia

# Nama tabel target — ganti jika tabel dipindah atau rename di env lain
TABLE_NAME=customer_aggregation
